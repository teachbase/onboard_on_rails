<div class="oor-page-header">
  <h1>Tours</h1>
  <div class="oor-page-header__actions">
    <%= link_to "New Tour", new_admin_tour_path, class: "oor-btn oor-btn--primary" %>
  </div>
</div>

<div class="oor-filter-bar">
  <%= link_to "All", admin_tours_path, class: "oor-btn oor-btn--sm #{'active' if params[:status].blank?}" %>
  <% OnboardOnRails::Tour::STATUSES.each do |status| %>
    <%= link_to status.capitalize, admin_tours_path(status: status), class: "oor-btn oor-btn--sm #{'active' if params[:status] == status}" %>
  <% end %>
</div>

<% if @tours.any? %>
  <table class="oor-table">
    <thead>
      <tr>
        <th>Name</th>
        <th>Status</th>
        <th>Steps</th>
        <th>URL Pattern</th>
        <th>Trigger</th>
        <th>Priority</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @tours.each do |tour| %>
        <%= render partial: "onboard_on_rails/admin/tours/tour", locals: { tour: tour } %>
      <% end %>
    </tbody>
  </table>
<% else %>
  <div class="oor-empty-state">
    <h3>No tours found</h3>
    <p>Create your first tour to get started with onboarding.</p>
    <%= link_to "Create Tour", new_admin_tour_path, class: "oor-btn oor-btn--primary" %>
  </div>
<% end %>
