<%= form_with(model: tour, url: tour.persisted? ? admin_tour_path(tour) : admin_tours_path, local: true) do |f| %>
  <% if tour.errors.any? %>
    <div class="oor-admin-flash oor-admin-flash--alert">
      <strong><%= t("onboard_on_rails.admin.tours.form.errors", count: tour.errors.count) %></strong>
      <ul>
        <% tour.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="oor-form-group">
    <%= f.label :name, t("onboard_on_rails.admin.tours.form.labels.name") %>
    <%= f.text_field :name, class: "oor-form-control" %>
  </div>

  <div class="oor-form-group">
    <%= f.label :description, t("onboard_on_rails.admin.tours.form.labels.description") %>
    <%= f.text_area :description, rows: 3 %>
  </div>

  <div class="oor-form-group">
    <%= f.label :status, t("onboard_on_rails.admin.tours.form.labels.status") %>
    <%= f.select :status, OnboardOnRails::Tour::STATUSES.map { |s| [t("onboard_on_rails.statuses.#{s}"), s] }, {}, {} %>
  </div>

  <div class="oor-form-group">
    <%= f.label :trigger_type, t("onboard_on_rails.admin.tours.form.labels.trigger_type") %>
    <%= f.select :trigger_type, OnboardOnRails::Tour::TRIGGER_TYPES.map { |t_type| [t("onboard_on_rails.trigger_types.#{t_type}"), t_type] }, {}, {} %>
  </div>

  <div class="oor-form-group">
    <%= f.label :trigger_event, t("onboard_on_rails.admin.tours.form.labels.trigger_event") %>
    <%= f.text_field :trigger_event %>
    <div class="oor-form-hint"><%= t("onboard_on_rails.admin.tours.form.hints.trigger_event") %></div>
  </div>

  <div class="oor-form-group">
    <%= f.label :url_pattern, t("onboard_on_rails.admin.tours.form.labels.url_pattern") %>
    <%= f.text_field :url_pattern, value: tour.url_pattern&.join(", ") %>
    <div class="oor-form-hint"><%= t("onboard_on_rails.admin.tours.form.hints.url_pattern") %></div>
  </div>

  <div class="oor-form-group">
    <%= f.label :frequency, t("onboard_on_rails.admin.tours.form.labels.frequency") %>
    <%= f.select :frequency, OnboardOnRails::Tour::FREQUENCIES.map { |fr| [t("onboard_on_rails.frequencies.#{fr}"), fr] }, {}, {} %>
  </div>

  <div class="oor-form-group">
    <%= f.label :theme, t("onboard_on_rails.admin.tours.form.labels.theme") %>
    <%= f.select :theme, OnboardOnRails::Tour::THEMES.map { |th| [t("onboard_on_rails.themes.#{th}"), th] }, {}, {} %>
  </div>

  <div class="oor-form-group">
    <%= f.label :priority, t("onboard_on_rails.admin.tours.form.labels.priority") %>
    <%= f.number_field :priority %>
    <div class="oor-form-hint"><%= t("onboard_on_rails.admin.tours.form.hints.priority") %></div>
  </div>

  <div class="oor-form-group">
    <%= f.label :schedule_start, t("onboard_on_rails.admin.tours.form.labels.schedule_start") %>
    <%= f.datetime_local_field :schedule_start %>
  </div>

  <div class="oor-form-group">
    <%= f.label :schedule_end, t("onboard_on_rails.admin.tours.form.labels.schedule_end") %>
    <%= f.datetime_local_field :schedule_end %>
  </div>

  <div class="oor-form-group">
    <%= f.label :ab_test_id, t("onboard_on_rails.admin.tours.form.labels.ab_test_id") %>
    <%= f.text_field :ab_test_id %>
    <div class="oor-form-hint"><%= t("onboard_on_rails.admin.tours.form.hints.ab_test_id") %></div>
  </div>

  <div class="oor-form-group">
    <%= f.label :ab_test_group, t("onboard_on_rails.admin.tours.form.labels.ab_test_group") %>
    <%= f.text_field :ab_test_group %>
    <div class="oor-form-hint"><%= t("onboard_on_rails.admin.tours.form.hints.ab_test_group") %></div>
  </div>

  <div class="oor-form-actions">
    <%= f.submit tour.persisted? ? t("onboard_on_rails.admin.tours.form.submit.update") : t("onboard_on_rails.admin.tours.form.submit.create"), class: "oor-btn oor-btn--primary" %>
    <% if tour.persisted? %>
      <%= link_to t("onboard_on_rails.admin.tours.form.cancel"), edit_admin_tour_path(tour), class: "oor-btn oor-btn--secondary" %>
    <% else %>
      <%= link_to t("onboard_on_rails.admin.tours.form.cancel"), admin_tours_path, class: "oor-btn oor-btn--secondary" %>
    <% end %>
  </div>
<% end %>
