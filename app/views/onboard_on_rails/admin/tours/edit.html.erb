<div class="oor-page-header">
  <h1>Edit Tour: <%= @tour.name %></h1>
  <div class="oor-page-header__actions">
    <%= link_to "Back to Tours", admin_tours_path, class: "oor-btn oor-btn--secondary" %>
  </div>
</div>

<div class="oor-panel-layout">
  <div class="oor-panel">
    <h3 class="oor-panel__title">Tour Settings</h3>
    <%= render "form", tour: @tour %>
  </div>

  <div class="oor-panel">
    <h3 class="oor-panel__title">
      Steps (<%= @tour.steps.count %>)
    </h3>

    <% if @tour.steps.any? %>
      <ul class="oor-step-list">
        <% @tour.steps.each do |step| %>
          <li class="oor-step-item">
            <div class="oor-step-item__info">
              <span class="oor-step-item__position"><%= step.position %></span>
              <div>
                <div class="oor-step-item__title"><%= step.title %></div>
                <div class="oor-step-item__selector"><%= step.selector %></div>
              </div>
            </div>
            <div class="oor-step-item__actions">
              <%= link_to "Edit", edit_admin_tour_step_path(@tour, step), class: "oor-btn oor-btn--sm oor-btn--secondary" %>
              <%= link_to "Delete", admin_tour_step_path(@tour, step), method: :delete, data: { confirm: "Delete this step?" }, class: "oor-btn oor-btn--sm oor-btn--danger" %>
            </div>
          </li>
        <% end %>
      </ul>
    <% else %>
      <div class="oor-empty-state">
        <p>No steps yet. Add your first step to this tour.</p>
      </div>
    <% end %>

    <div class="oor-form-actions">
      <%= link_to "Add Step", new_admin_tour_step_path(@tour), class: "oor-btn oor-btn--primary" %>
    </div>
  </div>
</div>
