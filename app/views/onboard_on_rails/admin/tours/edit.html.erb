<div class="oor-page-header">
  <h1><%= t("onboard_on_rails.admin.tours.edit.title", name: @tour.name) %></h1>
  <div class="oor-page-header__actions">
    <%= link_to t("onboard_on_rails.admin.tours.edit.back"), admin_tours_path, class: "oor-btn oor-btn--secondary" %>
  </div>
</div>

<div class="oor-panel-layout">
  <div class="oor-panel">
    <h3 class="oor-panel__title"><%= t("onboard_on_rails.admin.tours.edit.tour_settings") %></h3>
    <%= render "form", tour: @tour %>
  </div>

  <div class="oor-panel">
    <h3 class="oor-panel__title">
      <%= t("onboard_on_rails.admin.tours.edit.steps_title", count: @tour.steps.count) %>
    </h3>

    <% if @tour.steps.any? %>
      <ul class="oor-step-list">
        <% @tour.steps.each do |step| %>
          <li class="oor-step-item">
            <div class="oor-step-item__info">
              <span class="oor-step-item__position"><%= step.position %></span>
              <div>
                <div class="oor-step-item__title"><%= step.title %></div>
                <div class="oor-step-item__selector"><%= step.selector %></div>
              </div>
            </div>
            <div class="oor-step-item__actions">
              <%= link_to t("onboard_on_rails.admin.tours.edit.edit"), edit_admin_tour_step_path(@tour, step), class: "oor-btn oor-btn--sm oor-btn--secondary" %>
              <%= button_to t("onboard_on_rails.admin.tours.edit.delete"), admin_tour_step_path(@tour, step), method: :delete, class: "oor-btn oor-btn--sm oor-btn--danger", form: { style: "display:inline", data: { turbo_confirm: t("onboard_on_rails.admin.tours.edit.delete_step_confirm") } }, onclick: "return confirm('#{j t("onboard_on_rails.admin.tours.edit.delete_step_confirm")}')" %>
            </div>
          </li>
        <% end %>
      </ul>
    <% else %>
      <div class="oor-empty-state">
        <p><%= t("onboard_on_rails.admin.tours.edit.no_steps") %></p>
      </div>
    <% end %>

    <div class="oor-form-actions">
      <%= link_to t("onboard_on_rails.admin.tours.edit.add_step"), new_admin_tour_step_path(@tour), class: "oor-btn oor-btn--primary" %>
    </div>
  </div>
</div>
