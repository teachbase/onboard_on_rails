<%= form_with(model: [tour, step], url: step.persisted? ? admin_tour_step_path(tour, step) : admin_tour_steps_path(tour), local: true) do |f| %>
  <% if step.errors.any? %>
    <div class="oor-admin-flash oor-admin-flash--alert">
      <strong><%= t("onboard_on_rails.admin.steps.form.errors", count: step.errors.count) %></strong>
      <ul>
        <% step.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="oor-form-group">
    <%= f.label :title, t("onboard_on_rails.admin.steps.form.labels.title") %>
    <%= f.text_field :title %>
  </div>

  <div class="oor-form-group">
    <%= f.label :body, t("onboard_on_rails.admin.steps.form.labels.body") %>
    <%= f.text_area :body, rows: 4 %>
  </div>

  <div class="oor-form-group">
    <%= f.label :selector, t("onboard_on_rails.admin.steps.form.labels.selector") %>
    <div style="display: flex; gap: 8px;">
      <%= f.text_field :selector, style: "flex: 1;" %>
      <%= link_to t("onboard_on_rails.admin.steps.form.labels.pick"), onboard_on_rails.selector_picker_path, class: "oor-btn oor-btn--secondary", id: "oor-selector-picker-btn", target: "_blank" %>
    </div>
    <div class="oor-form-hint"><%= t("onboard_on_rails.admin.steps.form.hints.selector") %></div>
  </div>

  <div class="oor-form-group">
    <%= f.label :placement, t("onboard_on_rails.admin.steps.form.labels.placement") %>
    <div class="oor-placement-options">
      <% OnboardOnRails::Step::PLACEMENTS.each do |placement| %>
        <label>
          <%= f.radio_button :placement, placement %>
          <span><%= t("onboard_on_rails.placements.#{placement}") %></span>
        </label>
      <% end %>
    </div>
  </div>

  <div class="oor-form-group">
    <%= f.label :position, t("onboard_on_rails.admin.steps.form.labels.position") %>
    <%= f.number_field :position, min: 1 %>
  </div>

  <div class="oor-form-group">
    <%= f.label :action_type, t("onboard_on_rails.admin.steps.form.labels.action_type") %>
    <%= f.select :action_type, OnboardOnRails::Step::ACTION_TYPES.map { |a| [t("onboard_on_rails.action_types.#{a}"), a] }, {}, {} %>
  </div>

  <div class="oor-form-group">
    <%= f.label :action_value, t("onboard_on_rails.admin.steps.form.labels.action_value") %>
    <%= f.text_field :action_value %>
    <div class="oor-form-hint"><%= t("onboard_on_rails.admin.steps.form.hints.action_value") %></div>
  </div>

  <div class="oor-form-group">
    <%= f.label :wait_for_selector, t("onboard_on_rails.admin.steps.form.labels.wait_for_selector") %>
    <%= f.text_field :wait_for_selector %>
    <div class="oor-form-hint"><%= t("onboard_on_rails.admin.steps.form.hints.wait_for_selector") %></div>
  </div>

  <div class="oor-form-group">
    <%= f.label :url_pattern, t("onboard_on_rails.admin.steps.form.labels.url_pattern") %>
    <%= f.text_field :url_pattern %>
    <div class="oor-form-hint"><%= t("onboard_on_rails.admin.steps.form.hints.url_pattern") %></div>
  </div>

  <h4 class="oor-mb-sm" style="margin-top: 20px;"><%= t("onboard_on_rails.admin.steps.form.style_overrides") %></h4>

  <div class="oor-form-group">
    <label><%= t("onboard_on_rails.admin.steps.form.styles.background_color") %></label>
    <div class="oor-color-input">
      <input type="color" name="step[style_overrides][background_color]" value="<%= step.style_overrides&.dig('background_color') || '#ffffff' %>">
      <input type="text" name="step[style_overrides][background_color]" value="<%= step.style_overrides&.dig('background_color') || '#ffffff' %>" placeholder="#ffffff">
    </div>
  </div>

  <div class="oor-form-group">
    <label><%= t("onboard_on_rails.admin.steps.form.styles.text_color") %></label>
    <div class="oor-color-input">
      <input type="color" name="step[style_overrides][text_color]" value="<%= step.style_overrides&.dig('text_color') || '#2d3436' %>">
      <input type="text" name="step[style_overrides][text_color]" value="<%= step.style_overrides&.dig('text_color') || '#2d3436' %>" placeholder="#2d3436">
    </div>
  </div>

  <div class="oor-form-group">
    <label><%= t("onboard_on_rails.admin.steps.form.styles.font_family") %></label>
    <select name="step[style_overrides][font_family]">
      <option value=""><%= t("onboard_on_rails.admin.steps.form.styles.default_system") %></option>
      <% %w[Arial Helvetica Georgia Times\ New\ Roman Courier\ New Verdana].each do |font| %>
        <option value="<%= font %>" <%= 'selected' if step.style_overrides&.dig('font_family') == font %>><%= font %></option>
      <% end %>
    </select>
  </div>

  <div class="oor-form-group">
    <label><%= t("onboard_on_rails.admin.steps.form.styles.font_size") %></label>
    <select name="step[style_overrides][font_size]">
      <option value=""><%= t("onboard_on_rails.admin.steps.form.styles.default") %></option>
      <% %w[12px 13px 14px 15px 16px 18px 20px].each do |size| %>
        <option value="<%= size %>" <%= 'selected' if step.style_overrides&.dig('font_size') == size %>><%= size %></option>
      <% end %>
    </select>
  </div>

  <div class="oor-form-group">
    <label><%= t("onboard_on_rails.admin.steps.form.styles.border_radius") %></label>
    <select name="step[style_overrides][border_radius]">
      <option value=""><%= t("onboard_on_rails.admin.steps.form.styles.default_radius") %></option>
      <% %w[0px 4px 6px 8px 12px 16px 24px].each do |radius| %>
        <option value="<%= radius %>" <%= 'selected' if step.style_overrides&.dig('border_radius') == radius %>><%= radius %></option>
      <% end %>
    </select>
  </div>

  <div class="oor-form-group">
    <label><%= t("onboard_on_rails.admin.steps.form.styles.button_color") %></label>
    <div class="oor-color-input">
      <input type="color" name="step[style_overrides][button_color]" value="<%= step.style_overrides&.dig('button_color') || '#6c5ce7' %>">
      <input type="text" name="step[style_overrides][button_color]" value="<%= step.style_overrides&.dig('button_color') || '#6c5ce7' %>" placeholder="#6c5ce7">
    </div>
  </div>

  <div class="oor-form-actions">
    <%= f.submit step.persisted? ? t("onboard_on_rails.admin.steps.form.submit.update") : t("onboard_on_rails.admin.steps.form.submit.create"), class: "oor-btn oor-btn--primary" %>
    <%= link_to t("onboard_on_rails.admin.steps.form.cancel"), edit_admin_tour_path(tour), class: "oor-btn oor-btn--secondary" %>
  </div>
<% end %>
